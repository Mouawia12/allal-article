# ─── Backend API ──────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8080
REACT_APP_API_TIMEOUT=15000

# ─── Auth / Security ──────────────────────────────────────────────────────────
REACT_APP_TOKEN_KEY=token
REACT_APP_TENANT_KEY=tenantId
REACT_APP_USER_KEY=user
REACT_APP_COOKIE_DOMAIN=

# ─── AI Services ──────────────────────────────────────────────────────────────
# Keep provider API keys in the backend only. The frontend talks to backend
# settings/test endpoints and must not bundle OpenAI or Anthropic secrets.
REACT_APP_AI_GATEWAY_URL=http://localhost:8080/api/settings/ai

# ─── External Storage ─────────────────────────────────────────────────────────
REACT_APP_S3_BUCKET=
REACT_APP_S3_REGION=eu-west-3
REACT_APP_S3_ACCESS_KEY=
REACT_APP_S3_SECRET_KEY=
REACT_APP_S3_ENDPOINT=https://s3.eu-west-3.amazonaws.com

REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=
REACT_APP_CLOUDINARY_API_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
REACT_APP_ENABLE_AI=false
REACT_APP_ENABLE_STORAGE=false
REACT_APP_ENABLE_MULTI_TENANT=true

# ─── App Info ─────────────────────────────────────────────────────────────────
REACT_APP_NAME=Allal ERP
REACT_APP_VERSION=1.0.0
GENERATE_SOURCEMAP=false
